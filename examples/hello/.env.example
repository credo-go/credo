# Environment variable overrides for Credo hello world app.
#
# .env files do not require a prefix — all entries are loaded.
# Process env vars require the CREDO_ prefix (configurable via config.WithPrefix).
#
# Naming convention:
#   __     double underscore = nesting separator (dot)
#   _      single underscore = stays as-is within a segment
#
# Precedence (lowest to highest):
#   1. config.yaml
#   2. .env file
#   3. Process environment variables

SERVER__HOST=0.0.0.0
SERVER__PORT=8080
