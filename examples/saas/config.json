{
  "_comment": "Comprehensive Credo configuration for a SaaS application.",

  "server": {
    "host": "0.0.0.0",
    "port": 8080,
    "read_timeout": "15s",
    "write_timeout": "15s",
    "idle_timeout": "60s",
    "read_header_timeout": "5s",
    "max_header_bytes": 1048576
  },

  "databases": {
    "default": {
      "driver": "postgres",
      "host": "localhost",
      "port": 5432,
      "name": "saas_app",
      "user": "app_user",
      "password": "",
      "max_open": 25,
      "max_idle": 5,
      "max_lifetime": "30m",
      "ssl_mode": "require"
    }
  },

  "i18n": {
    "dir": "locales/",
    "default": "en"
  },

  "auth": {
    "jwt": {
      "header": "Authorization",
      "prefix": "Bearer",
      "signing_method": "RS256"
    },
    "api_key": {
      "header": "X-API-Key"
    },
    "basic": {
      "realm": "SaaS Admin"
    }
  },

  "middleware": {
    "cors": {
      "allow_origins": ["https://app.example.com", "https://*.example.com"],
      "allow_methods": ["GET", "POST", "PUT", "PATCH", "DELETE"],
      "allow_headers": ["Authorization", "Content-Type", "X-Request-Id"],
      "allow_credentials": true,
      "expose_headers": ["X-Request-Id", "X-RateLimit-Remaining"],
      "max_age": 86400
    },
    "compress": {
      "level": 5,
      "types": [
        "text/html",
        "text/css",
        "text/plain",
        "application/json",
        "application/javascript",
        "image/svg+xml"
      ]
    },
    "rate_limit": {
      "tokens": 100,
      "interval": "1m"
    },
    "recover": {
      "disable_stack_trace": false,
      "stack_size": 8192
    },
    "request_id": {
      "header": "X-Request-Id",
      "limit": 64
    },
    "secure": {
      "xss_protection": "1; mode=block",
      "content_type_nosniff": "nosniff",
      "x_frame_options": "DENY",
      "hsts_max_age": 31536000,
      "hsts_exclude_subdomains": false,
      "hsts_preload_enabled": true,
      "content_security_policy": "default-src 'self'; script-src 'self'",
      "csp_report_only": false,
      "referrer_policy": "strict-origin-when-cross-origin"
    },
    "timeout": {
      "timeout": "30s"
    }
  },

  "app": {
    "name": "My SaaS App",
    "environment": "production",
    "debug": false
  }
}
