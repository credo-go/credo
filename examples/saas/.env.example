# Environment variable overrides for Credo SaaS application.
#
# .env files do not require a prefix — all entries are loaded and normalized.
# Process env vars require the CREDO_ prefix (configurable via config.WithPrefix).
#
# Naming convention:
#   __  (double)         nesting separator (becomes dot in key path)
#   _   (single)         stays as-is within a key segment
#
# Examples (.env → config key):
#   SERVER__PORT             → server.port
#   SERVER__READ_TIMEOUT     → server.read_timeout
#   DATABASES__DEFAULT__HOST → databases.default.host
#
# Process env equivalents (with CREDO_ prefix):
#   CREDO_SERVER__PORT, CREDO_SERVER__READ_TIMEOUT, etc.
#
# Precedence (lowest to highest):
#   1. config.yaml / config.json
#   2. .env file
#   3. Process environment variables

# --- Server [framework-read] ---
SERVER__HOST=0.0.0.0
SERVER__PORT=8080
SERVER__READ_TIMEOUT=15s
SERVER__WRITE_TIMEOUT=15s
SERVER__IDLE_TIMEOUT=60s
SERVER__READ_HEADER_TIMEOUT=5s
SERVER__MAX_HEADER_BYTES=1048576

# --- Databases [user-read] ---
DATABASES__DEFAULT__DRIVER=postgres
DATABASES__DEFAULT__HOST=localhost
DATABASES__DEFAULT__PORT=5432
DATABASES__DEFAULT__NAME=saas_app
DATABASES__DEFAULT__USER=app_user
DATABASES__DEFAULT__PASSWORD=secret
DATABASES__DEFAULT__MAX_OPEN=25
DATABASES__DEFAULT__MAX_IDLE=5
DATABASES__DEFAULT__MAX_LIFETIME=30m
DATABASES__DEFAULT__SSL_MODE=require
# DATABASES__READ_REPLICA__HOST=replica-db.internal
# DATABASES__READ_REPLICA__PASSWORD=replica_secret

# --- i18n [user-read] ---
I18N__DIR=locales/
I18N__DEFAULT=en

# --- Auth [user-read] ---
AUTH__JWT__SIGNING_METHOD=RS256
# AUTH__JWT__QUERY=token
# AUTH__JWT__COOKIE=jwt
AUTH__API_KEY__HEADER=X-API-Key
AUTH__BASIC__REALM=SaaS Admin

# --- Middleware [aspirational] ---
MIDDLEWARE__RATE_LIMIT__TOKENS=100
MIDDLEWARE__RATE_LIMIT__INTERVAL=1m
MIDDLEWARE__TIMEOUT__TIMEOUT=30s
MIDDLEWARE__SECURE__HSTS_MAX_AGE=31536000
MIDDLEWARE__COMPRESS__LEVEL=5
MIDDLEWARE__REQUEST_ID__HEADER=X-Request-Id

# --- Application [user-read] ---
APP__NAME=My SaaS App
APP__ENVIRONMENT=production
APP__DEBUG=false
